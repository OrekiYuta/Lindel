{
  "manifest_version": 3,
  "name": "Lindel",
  "version": "1.0.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "lindel@extension",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "tabs",
    "storage",
    "bookmarks"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_icon": {
      "32": "assets/img/pokemon-icons/png/1x/202-wobbuffet.png",
      "64": "assets/img/pokemon-icons/png/2x/202-wobbuffet@2x.png",
      "96": "assets/img/pokemon-icons/png/3x/202-wobbuffet@3x.png"
    }
  },
  "options_page": "lindel.html",
  "background": {
    "service_worker": "assets/js/background.js",
    "scripts": ["assets/js/background.js"]
  },
  "icons": {
    "32": "assets/img/pokemon-icons/png/1x/202-wobbuffet.png",
    "64": "assets/img/pokemon-icons/png/2x/202-wobbuffet@2x.png",
    "96": "assets/img/pokemon-icons/png/3x/202-wobbuffet@3x.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "css": [
        "assets/css/wording-assistant.css"
      ],
      "js": [
        "assets/js/wording-assistant.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/config/prompt.yml"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
